APP_ENV=development
APP_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:8000
DATABASE_URL=postgresql+psycopg://running_planner:change-me@localhost:5432/running_planner
SESSION_SECRET=replace-with-long-random-secret
# Used only to bootstrap the first admin user when the user_accounts table is empty.
APP_USERNAME=michael
APP_PASSWORD=
SESSION_COOKIE_SECURE=false
SESSION_TTL_SECONDS=1209600
TOKEN_ENCRYPTION_KEY=replace-with-fernet-compatible-key

STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:8000/api/auth/strava/callback
STRAVA_SYNC_ENABLED=true
STRAVA_SYNC_INTERVAL_SECONDS=1800
STRAVA_SYNC_LOOKBACK_DAYS=14
STRAVA_WEBHOOK_ENABLED=false
STRAVA_WEBHOOK_VERIFY_TOKEN=
STRAVA_WEBHOOK_SUBSCRIPTION_ID=
STRAVA_WEBHOOK_MAX_ATTEMPTS=5

AI_PROVIDER=stub
AI_API_KEY=
# Keep empty so the browser uses same-origin /api. Vite proxies this locally.
VITE_API_BASE_URL=

FRONTEND_MIN_VERSION=0.1.0
BACKEND_VERSION=0.1.0
SCHEMA_VERSION=2026_06_29_006
FORCE_RELOAD=false
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# For the Caddy-served deployment at https://run.home.arpa or
# https://run.creeth.net, update these values:
# APP_ENV=production
# APP_BASE_URL=https://run.creeth.net
# API_BASE_URL=https://run.creeth.net
# STRAVA_REDIRECT_URI=https://run.creeth.net/api/auth/strava/callback
# SESSION_COOKIE_SECURE=true
# CORS_ORIGINS=https://run.home.arpa,https://run.creeth.net
# VITE_API_BASE_URL=
